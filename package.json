{
  "name": "@newbase-clawchat/hermes-clawchat",
  "version": "0.1.0",
  "description": "ClawChat gateway installer for Hermes Agent",
  "license": "UNLICENSED",
  "type": "commonjs",
  "bin": {
    "hermes-clawchat": "bin/hermes-clawchat.js"
  },
  "scripts": {
    "test:node": "node bin/hermes-clawchat.js --help && node bin/hermes-clawchat.js install --dry-run",
    "pack:check": "npm pack --dry-run"
  },
  "files": [
    "__init__.py",
    "plugin.yaml",
    "after-install.md",
    "bin/hermes-clawchat.js",
    "scripts/install-package.sh",
    "skills/clawchat/SKILL.md",
    "src/clawchat_gateway/*.py",
    "pyproject.toml",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  }
}
